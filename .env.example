# Cashier app config
# Copy to .env and adjust as needed.

# Backend API base URL (the same one the admin app uses)
VITE_API_BASE_URL=http://localhost:3000/api

# Where the admin / manager app is reachable. The cashier opens the
# booking detail there for actions it doesn't handle locally
# (take payment, send waiver, etc.).
VITE_ADMIN_URL=http://localhost:5173
